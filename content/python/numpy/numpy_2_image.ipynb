   "source": [
    "import numpy as np\n",
    "import cv2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Done\n"
     ]
    }
   ],
   "source": [
    "r = np.reshape(np.arange(256*256)%256,(256,256)) \n",
    "\n",
    "g = np.zeros_like(r)\n",
    "\n",
    "b = r.T\n",
    "\n",
    "cv2.imwrite('/Users/rajacsp/datasets/barcode_images/gradients.png', np.dstack([b,g,r])) \n",
    "\n",
    "print('Done')"
   ]
  },
